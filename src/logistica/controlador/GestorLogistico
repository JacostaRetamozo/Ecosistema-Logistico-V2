package logistica.controlador;

import logistica.modelo.Vehiculo;
import logistica.modelo.IConectable;
import java.util.ArrayList;
import java.util.Comparator;
import java.util.List;
import java.util.Optional;
import java.util.stream.Collectors;

/**
 * Controlador centralizado para la gestión de la flota vehicular.
 * Implementa operaciones CRUD y procesamiento avanzado de datos utilizando
 * expresiones lambda y la API Stream de Java de forma eficiente.
 * @author [José Acosta]
 * @version 2.0
 */
public class GestorLogistico {

    /**
     * Colección en memoria que almacena los vehículos del ecosistema.
     * Se utiliza List con implementación ArrayList para optimizar el acceso por índice.
     */
    private final List<Vehiculo> flota;

    /**
     * Constructor que inicializa la colección interna de la flota.
     */
    public GestorLogistico() {
        this.flota = new ArrayList<>();
    }

    // =========================================================================
    // EJERCICIO 1: OPERACIONES CRUD
    // =========================================================================

    /**
     * Registra un nuevo vehículo en la flota si no existe un ID duplicado.
     * @param v El objeto Vehiculo a incorporar.
     * @return true si se registró con éxito, false si es nulo o ya existe.
     */
    public boolean crearVehiculo(Vehiculo v) {
        if (v == null || buscarVehiculo(v.getId()).isPresent()) {
            return false;
        }
        return flota.add(v);
    }

    /**
     * Retorna la lista completa de vehículos registrados.
     * Aplica encapsulamiento seguro devolviendo una nueva lista con las referencias.
     * @return List de Vehiculo.
     */
    public List<Vehiculo> listarVehiculos() {
        return new ArrayList<>(flota);
    }

    /**
     * Busca un vehículo específico dentro de la colección por su ID.
     * @param id Identificador alfanumérico del vehículo.
     * @return Un Optional que contiene el Vehiculo si fue hallado, o vacío.
     */
    public Optional<Vehiculo> buscarVehiculo(String id) {
        if (id == null || id.trim().isEmpty()) {
            return Optional.empty();
        }
        return flota.stream()
                    .filter(v -> v.getId().equalsIgnoreCase(id.trim()))
                    .findFirst();
    }

    /**
     * Reemplaza un vehículo existente por una versión actualizada basada en su ID.
     * @param id Identificador del vehículo a modificar.
     * @param vehiculoActualizado Nuevo objeto con los datos modificados.
     * @return true si la modificación fue exitosa, false en caso contrario.
     */
    public boolean modificarVehiculo(String id, Vehiculo vehiculoActualizado) {
        if (id == null || vehiculoActualizado == null || !id.equalsIgnoreCase(vehiculoActualizado.getId())) {
            return false;
        }

        for (int i = 0; i < flota.size(); i++) {
            if (flota.get(i).getId().equalsIgnoreCase(id)) {
                flota.set(i, vehiculoActualizado);
                return true;
            }
        }
        return false;
    }

    /**
     * Elimina un vehículo de la flota según su identificador único.
     * @param id Identificador del vehículo a remover.
     * @return true si se eliminó correctamente, false si no se encontró.
     */
    public boolean eliminarVehiculo(String id) {
        if (id == null) {
            return false;
        }
        return flota.removeIf(v -> v.getId().equalsIgnoreCase(id.trim()));
    }

    // =========================================================================
    // EJERCICIO 2: EXPRESIONES LAMBDA
    // =========================================================================

    /**
     * Recorre la colección de la flota y despliega la información en consola.
     * Aplica una expresión lambda interna mediante el método forEach de la colección.
     */
    public void mostrarVehiculos() {
        flota.forEach(v -> System.out.println(v.toString()));
    }

    // =========================================================================
    // EJERCICIO 3: PROCESAMIENTO CON STREAMS
    // =========================================================================

    /**
     * Filtra la colección para obtener únicamente los vehículos que poseen
     * capacidades de comunicación activa (implementan la interfaz IConectable).
     * @return List de vehículos conectables.
     */
    public List<Vehiculo> obtenerVehiculosConectables() {
        return flota.stream()
                    .filter(v -> v instanceof IConectable)
                    .collect(Collectors.toList());
    }

    /**
     * Procesa la flota para extraer una lista exclusiva de sus identificadores alfanuméricos.
     * @return List de Strings con las IDs de los vehículos.
     */
    public List<String> obtenerListaDeIds() {
        return flota.stream()
                    .map(Vehiculo::getId)
                    .collect(Collectors.toList());
    }

    /**
     * Evalúa y cuenta la cantidad total de elementos dentro del flujo de datos.
     * @return Total de vehículos de tipo long.
     */
    public long contarVehiculos() {
        return flota.stream().count();
    }

    /**
     * Filtra la estructura de datos según la clase específica enviada por parámetro.
     * @param tipo Subclase reflexiva de Vehiculo (ej: CamionAutonomo.class).
     * @return List conteniendo únicamente las instancias que correspondan a dicho tipo.
     */
    public List<Vehiculo> buscarVehiculosPorTipo(Class<? extends Vehiculo> tipo) {
        if (tipo == null) {
            return new ArrayList<>();
        }
        return flota.stream()
                    .filter(tipo::isInstance)
                    .collect(Collectors.toList());
    }

    // =========================================================================
    // EJERCICIO 4: ORDENAMIENTO
    // =========================================================================

    /**
     * Ordena la colección interna de forma ascendente basándose en el ID alfanumérico.
     */
    public void ordenarPorId() {
        flota.sort(Comparator.comparing(Vehiculo::getId));
    }

    /**
     * Ordena la colección alfabéticamente basándose en el nombre de la clase del objeto.
     */
    public void ordenarPorTipo() {
        flota.sort(Comparator.comparing(v -> v.getClass().getSimpleName()));
    }
    // =========================================================================
    // EJERCICIO 6: MEJORA PROPUESTA (COMPLEMENTO)
    // =========================================================================

    /**
     * CLASIFICACIÓN: Agrupa los vehículos de la flota según su tipo (clase concreta).
     * Utiliza Collectors.groupingBy para clasificar los elementos de forma funcional.
     * @return Un Map donde la clave es el nombre de la clase y el valor es la lista de vehículos asociados.
     */
    public java.util.Map<String, List<Vehiculo>> clasificarVehiculosPorTipo() {
        return flota.stream()
                    .collect(Collectors.groupingBy(v -> v.getClass().getSimpleName()));
    }

    /**
     * BÚSQUEDA AVANZADA: Filtra las unidades que implementan IConectable y que 
     * actualmente se encuentran con el estado "Conectado".
     * @return List de vehículos conectables en línea.
     */
    public List<Vehiculo> buscarConectablesActivos() {
        return flota.stream()
                    .filter(v -> v instanceof IConectable)
                    .filter(v -> ((IConectable) v).obtenerEstadoConexion().toLowerCase().contains("conectado"))
                    .collect(Collectors.toList());
    }
}
